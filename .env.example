# API Configuration
# Copy this file to `.env` and adjust values for your environment.

# development | production
NODE_ENV=development

# Backend REST API (must include /api/v1)
NEXT_PUBLIC_API_BASE_URL=http://localhost:9879/api/v1

# Socket.IO server (same host as backend, no /api/v1 path)
NEXT_PUBLIC_SOCKET_URL=http://localhost:9879

# Optional: base URL for images if different from full S3 URLs in API responses
# NEXT_PUBLIC_IMAGE_BASE_URL=

# --- Production example ---
# NODE_ENV=production
# NEXT_PUBLIC_API_BASE_URL=https://api.jkcabinetryct.com/api/v1
# NEXT_PUBLIC_SOCKET_URL=https://api.jkcabinetryct.com
